@model Lab1.Models.Student
@{
    <h1>@Model.Name @Model.Surname</h1>
    <p>
        Data urodzenia: @Model.BirthDate.ToShortDateString();
    </p>
    <p>
        Numer indeksu: @Model.Index
    </p>
    <p>
        Kierunek studiów: @Model.Faculty
    </p>
}
