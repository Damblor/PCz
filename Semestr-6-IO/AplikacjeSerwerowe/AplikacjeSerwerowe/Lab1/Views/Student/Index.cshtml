@model List<Lab1.Models.Student>
@{
    <p>
        Studenci:
        <ul>
            @{
                for(int i = 0; i < Model.Count; i++)
                {
                    <li>
                        <a asp-controller="student" asp-action="details" asp-route-id="i">@Model[i].Name @Model[i].Surname</a>
                    </li>
                }      
            }
        </ul>
    </p>
}
